# SACP Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# --- Database (PostgreSQL 16) ---
# Placeholder secret values trip the V16 startup validator (audit H-04) —
# the orchestrator refuses to bind ports if these strings reach a real
# `.env`. Replace before first run.
#
# Audit Critical-4: the orchestrator runtime connects as the restricted
# `sacp_app` role, NOT the bootstrap superuser. The four SACP_*_PASSWORD
# values below are consumed by scripts/db-init/00-create-sacp-roles.sh
# the first time the postgres container's data volume is initialized;
# they create the four least-privilege roles (admin, app, cleanup,
# audit_reader). Alembic migration 026 then grants per-table privileges.
SACP_DATABASE_URL=postgresql://sacp_app:REPLACE_ME_BEFORE_FIRST_RUN@localhost:5432/sacp
POSTGRES_USER=sacp
POSTGRES_PASSWORD=REPLACE_ME_BEFORE_FIRST_RUN
POSTGRES_DB=sacp

# --- Role bootstrap secrets (audit Critical-4) ---
# Postgres init consumes these once on first cluster init. Required to be
# set; the compose `:?` form refuses to start if any are unset.
SACP_ADMIN_PASSWORD=REPLACE_ME_BEFORE_FIRST_RUN
SACP_APP_PASSWORD=REPLACE_ME_BEFORE_FIRST_RUN
SACP_CLEANUP_PASSWORD=REPLACE_ME_BEFORE_FIRST_RUN
SACP_AUDIT_READER_PASSWORD=REPLACE_ME_BEFORE_FIRST_RUN

# --- Role-scoped DSNs (audit Critical-4) ---
# The compose stack wires SACP_DATABASE_URL_MIGRATIONS automatically into
# the sacp-migrate one-shot service from SACP_ADMIN_PASSWORD; uncomment
# below only when running migrations / cleanup outside the compose stack.
# SACP_DATABASE_URL_MIGRATIONS=postgresql://sacp_admin:REPLACE_ME_BEFORE_FIRST_RUN@localhost:5432/sacp
# SACP_DATABASE_URL_CLEANUP=postgresql://sacp_cleanup:REPLACE_ME_BEFORE_FIRST_RUN@localhost:5432/sacp
# SACP_DATABASE_URL_AUDIT=postgresql://sacp_audit_reader:REPLACE_ME_BEFORE_FIRST_RUN@localhost:5432/sacp

# --- Dev-mode escape (audit Critical-4) ---
# Set to 1 ONLY for local development against a database without the SACP
# role bootstrap. Lifts the `username must be 'sacp_app'` assertion on
# SACP_DATABASE_URL. MUST stay 0 in any deployment serving real users --
# Critical-4 hardens the runtime DSN against connecting as superuser, and
# SACP_DEV_MODE=1 + a superuser DSN restores the pre-audit attack surface.
SACP_DEV_MODE=0

# --- Encryption ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SACP_ENCRYPTION_KEY=REPLACE_ME_BEFORE_FIRST_RUN

# --- Auth-token lookup HMAC key (audit C-02) ---
# Indexed token resolution to avoid O(N) bcrypt scans on every authenticate().
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Distinct from SACP_ENCRYPTION_KEY -- different threat model, separate rotation cadence.
SACP_AUTH_LOOKUP_KEY=REPLACE_ME_BEFORE_FIRST_RUN

# --- Web UI cookie-signing key (audit M-02) ---
# Independent from SACP_ENCRYPTION_KEY so a leak of either secret does not
# compromise both at-rest encryption AND session-cookie integrity.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SACP_WEB_UI_COOKIE_KEY=REPLACE_ME_BEFORE_FIRST_RUN

# --- Connection Pool ---
POOL_MIN_SIZE=2
POOL_MAX_SIZE=10
STATEMENT_TIMEOUT_MS=30000
IDLE_TIMEOUT_MS=60000

# --- Ports ---
SACP_MCP_PORT=8750
SACP_WEB_PORT=8751

# --- Web UI cookie Secure flag (advanced) ---
# The session cookie's Secure flag is auto-detected from the inbound
# request scheme: HTTPS gets Secure, HTTP does not. Behind a TLS-
# terminating reverse proxy, set SACP_TRUST_PROXY=1 (below) so the
# X-Forwarded-Proto header is honored.
#
# Set SACP_WEB_UI_INSECURE_COOKIES=1 to FORCE the Secure flag off
# regardless of scheme. Unnecessary for normal LAN/HTTP use because
# of auto-detect; keep it for explicit operator control.
# SACP_WEB_UI_INSECURE_COOKIES=0

# --- Reverse-proxy trust (advanced) ---
# Set to 1 only when SACP runs behind a reverse proxy you control
# that overwrites X-Forwarded-For / X-Forwarded-Proto. Affects IP
# binding (auth) and cookie Secure-flag auto-detect. Trusting these
# headers without an actual proxy in front lets a hostile client
# spoof either signal, so leave at 0 in direct LAN deployments.
# SACP_TRUST_PROXY=0

# --- MCP API docs (Swagger / OpenAPI) ---
# Off by default so the MCP schema isn't a free reconnaissance
# surface in production. Set to 1 for dev/troubleshooting to expose
# /docs, /redoc, and /openapi.json on the MCP port (8750).
# SACP_ENABLE_DOCS=0

# SACP Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# --- Database (PostgreSQL 16) ---
# Placeholder secret values trip the V16 startup validator (audit H-04) —
# the orchestrator refuses to bind ports if these strings reach a real
# `.env`. Replace before first run.
SACP_DATABASE_URL=postgresql://sacp:REPLACE_ME_BEFORE_FIRST_RUN@localhost:5432/sacp
POSTGRES_USER=sacp
POSTGRES_PASSWORD=REPLACE_ME_BEFORE_FIRST_RUN
POSTGRES_DB=sacp

# --- Encryption ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SACP_ENCRYPTION_KEY=REPLACE_ME_BEFORE_FIRST_RUN

# --- Connection Pool ---
POOL_MIN_SIZE=2
POOL_MAX_SIZE=10
STATEMENT_TIMEOUT_MS=30000
IDLE_TIMEOUT_MS=60000

# --- Ports ---
SACP_MCP_PORT=8750
SACP_WEB_PORT=8751

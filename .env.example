# SACP Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# --- Database (PostgreSQL 16) ---
SACP_DATABASE_URL=postgresql://sacp:changeme@localhost:5432/sacp
POSTGRES_USER=sacp
POSTGRES_PASSWORD=changeme
POSTGRES_DB=sacp

# --- Encryption ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SACP_ENCRYPTION_KEY=generate-with-python-fernet

# --- Ports ---
SACP_MCP_PORT=8750
SACP_WEB_PORT=8751

# SACP Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# --- Database (PostgreSQL 16) ---
# Placeholder secret values trip the V16 startup validator (audit H-04) —
# the orchestrator refuses to bind ports if these strings reach a real
# `.env`. Replace before first run.
SACP_DATABASE_URL=postgresql://sacp:REPLACE_ME_BEFORE_FIRST_RUN@localhost:5432/sacp
POSTGRES_USER=sacp
POSTGRES_PASSWORD=REPLACE_ME_BEFORE_FIRST_RUN
POSTGRES_DB=sacp

# --- Encryption ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SACP_ENCRYPTION_KEY=REPLACE_ME_BEFORE_FIRST_RUN

# --- Auth-token lookup HMAC key (audit C-02) ---
# Indexed token resolution to avoid O(N) bcrypt scans on every authenticate().
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Distinct from SACP_ENCRYPTION_KEY -- different threat model, separate rotation cadence.
SACP_AUTH_LOOKUP_KEY=REPLACE_ME_BEFORE_FIRST_RUN

# --- Web UI cookie-signing key (audit M-02) ---
# Independent from SACP_ENCRYPTION_KEY so a leak of either secret does not
# compromise both at-rest encryption AND session-cookie integrity.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SACP_WEB_UI_COOKIE_KEY=REPLACE_ME_BEFORE_FIRST_RUN

# --- Connection Pool ---
POOL_MIN_SIZE=2
POOL_MAX_SIZE=10
STATEMENT_TIMEOUT_MS=30000
IDLE_TIMEOUT_MS=60000

# --- Ports ---
SACP_MCP_PORT=8750
SACP_WEB_PORT=8751

# --- Web UI cookie Secure flag (advanced) ---
# The session cookie's Secure flag is auto-detected from the inbound
# request scheme: HTTPS gets Secure, HTTP does not. Behind a TLS-
# terminating reverse proxy, set SACP_TRUST_PROXY=1 (below) so the
# X-Forwarded-Proto header is honored.
#
# Set SACP_WEB_UI_INSECURE_COOKIES=1 to FORCE the Secure flag off
# regardless of scheme. Unnecessary for normal LAN/HTTP use because
# of auto-detect; keep it for explicit operator control.
# SACP_WEB_UI_INSECURE_COOKIES=0

# --- Reverse-proxy trust (advanced) ---
# Set to 1 only when SACP runs behind a reverse proxy you control
# that overwrites X-Forwarded-For / X-Forwarded-Proto. Affects IP
# binding (auth) and cookie Secure-flag auto-detect. Trusting these
# headers without an actual proxy in front lets a hostile client
# spoof either signal, so leave at 0 in direct LAN deployments.
# SACP_TRUST_PROXY=0

# --- MCP API docs (Swagger / OpenAPI) ---
# Off by default so the MCP schema isn't a free reconnaissance
# surface in production. Set to 1 for dev/troubleshooting to expose
# /docs, /redoc, and /openapi.json on the MCP port (8750).
# SACP_ENABLE_DOCS=0

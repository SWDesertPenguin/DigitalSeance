* text=auto

# Lockfiles must stay LF on every platform — `uv run` (invoked by the
# `standards-lint` pre-commit hook) re-reads uv.lock during hook setup and
# the Windows checkout's CRLF normalization flips line endings, creating a
# phantom modification that fails the hook on every commit. eol=lf pins the
# checkout to match what tools write back.
*.lock text eol=lf

# Shell scripts must stay LF so they remain executable inside Linux
# containers after a Windows checkout. Affects scripts/db-init/*.sh
# (mounted into the Postgres init dir) and .claude/hooks/*.sh (Claude
# Code edit hooks). CRLF endings break bash invocation via shebang or
# entrypoint mount.
*.sh text eol=lf
